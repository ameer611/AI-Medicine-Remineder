# Telegram Bot Configuration
# Get your token from @BotFather
BOT_TOKEN=000000000:REPLACE_WITH_REAL_TELEGRAM_BOT_TOKEN

# LLM APIs
# Used for structured data extraction
CEREBRAS_API_KEY=REPLACE_WITH_CEREBRAS_API_KEY
# Used for OCR (Google Gemini)
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# OCR.space API Key (Optional if using Gemini OCR)
OCR_API_KEY=

# Database Configuration
# Format: mysql+aiomysql://user:password@host:port/dbname
# For Docker: mysql+aiomysql://dori:secret@mysql:3306/dori_scheduler
DATABASE_URL=mysql+aiomysql://dori:secret@localhost:3306/dori_scheduler

# Internal API Base URL
# For Docker (Bot -> API): http://api:8000
API_BASE_URL=http://localhost:8000
